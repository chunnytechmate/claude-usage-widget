# ── claude-usage-widget — local secrets ───────────────────────────
# Copy this file to ".env" and fill in your keys.
# ".env" is gitignored: it never leaves this machine and is never committed.
#
# Key resolution order for Z.AI (highest priority first):
#   1) ZAI_API_KEY environment variable
#   2) zaiApiKey in the widget config (%APPDATA%\claude-usage-widget)
#   3) this .env file
#
# Claude needs no key here — it reads the OAuth token Claude Code already
# stores at ~/.claude/.credentials.json.

# Z.AI API key — required only if you enable the Z.AI provider.
# Get it from your Z.AI dashboard. Leave blank to run in Claude-only mode.
ZAI_API_KEY=
